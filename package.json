{
  "name": "calibration-workbench",
  "version": "0.2.1",
  "private": true,
  "description": "Camera / fish-eye / hand-eye / chain calibration GUI for VR rigs.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite --config renderer/vite.config.js",
    "dev:electron": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "i18n:check": "node scripts/check-i18n-keys.mjs",
    "build:renderer": "npm run i18n:check && vite build --config renderer/vite.config.js",
    "build:backend": "bash scripts/build-backend.sh",
    "build:linux": "npm run build:renderer && electron-builder --linux",
    "build:win": "npm run build:renderer && electron-builder --win",
    "lint": "eslint --config .config/lint.cjs electron renderer/vite.config.js renderer/src",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "i18next": "^23.16.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.3"
  },
  "build": {
    "appId": "ai.calibration.workbench",
    "productName": "Calibration Workbench",
    "asar": true,
    "files": [
      "electron/**/*",
      "renderer/dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/app",
        "to": "backend/app",
        "filter": [
          "**/*.py"
        ]
      },
      {
        "from": "backend/requirements.txt",
        "to": "backend/requirements.txt"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Science",
      "icon": "build/icon-1024.png",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "directories": {
      "buildResources": "build",
      "output": "dist"
    }
  }
}
